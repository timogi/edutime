{
  "name": "edutime",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "dev": "npm run dev -w @edutime/web",
    "dev:mobile": "npm run start -w @edutime/mobile",
    "dev:mobile:ios": "npm run ios -w @edutime/mobile",
    "dev:mobile:android": "npm run android -w @edutime/mobile",
    "build:web": "npm run build -w @edutime/web",
    "build:shared": "npm run build -w @edutime/shared",
    "build:mobile:ios": "npm run eas:build:ios -w @edutime/mobile",
    "build:mobile:android": "npm run eas:build:android -w @edutime/mobile",
    "build:mobile:all": "npm run eas:build:all -w @edutime/mobile",
    "eas:build:ios": "npm run eas:build:ios -w @edutime/mobile",
    "eas:build:android": "npm run eas:build:android -w @edutime/mobile",
    "eas:build:all": "npm run eas:build:all -w @edutime/mobile",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "tsc --noEmit --workspaces"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "patch-package": "^8.0.0"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "@types/react": "~19.2.0",
    "react-native": "0.83.4",
    "tar": ">=7.5.13",
    "tmp": ">=0.2.4",
    "@xmldom/xmldom": "0.8.12",
    "jsdom": "^24.1.3",
    "@oclif/core": {
      "minimatch": "^10.2.5"
    },
    "eas-cli": {
      "minimatch": "5.1.9",
      "tar": "^7.5.13",
      "@xmldom/xmldom": "0.8.12",
      "ajv": "^8.18.0",
      "diff": "^8.0.4",
      "node-forge": "^1.3.4",
      "yaml": "^2.8.3",
      "@expo/plist": "0.5.2",
      "@expo/prebuild-config": {
        "@expo/config-plugins": {
          "@expo/plist": "0.5.2"
        }
      }
    },
    "@expo/plist": "0.5.2"
  },
  "engines": {
    "node": ">=20.19.4"
  }
}
